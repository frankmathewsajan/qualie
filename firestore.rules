rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Temporary development rule: allows the app's current client and server
      // Firestore access paths to work without auth while the project is still
      // in prototype mode. Replace this with scoped rules before production.
      allow read, write: if request.time < timestamp.date(2036, 3, 27);
    }
  }
}
